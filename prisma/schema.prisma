generator client {
  provider = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model Search {
  id          String    @id @default(cuid())
  input       String
  companyName String?
  companyUrl  String?
  companyType String?
  industry    String?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  contacts    Contact[]
  pitches     Pitch[]
  drafts      Draft[]
}

model Contact {
  id          String  @id @default(cuid())
  searchId    String
  search      Search  @relation(fields: [searchId], references: [id], onDelete: Cascade)
  name        String
  title       String?
  email       String?
  emailStatus String?
  linkedinUrl String?
  confidence  Int     @default(0)
  rank        Int     @default(0)
}

model Pitch {
  id         String  @id @default(cuid())
  searchId   String
  search     Search  @relation(fields: [searchId], references: [id], onDelete: Cascade)
  title      String
  angle      String
  rationale  String
  format     String?
}

model Draft {
  id        String   @id @default(cuid())
  searchId  String
  search    Search   @relation(fields: [searchId], references: [id], onDelete: Cascade)
  contactId String?
  channel   String
  subject   String?
  body      String
  version   Int      @default(1)
  createdAt DateTime @default(now())
}
